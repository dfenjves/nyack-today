// Nyack Today - Database Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Event categories
enum Category {
  MUSIC
  COMEDY
  MOVIES
  THEATER
  FAMILY_KIDS
  FOOD_DRINK
  SPORTS_RECREATION
  COMMUNITY_GOVERNMENT
  ART_GALLERIES
  CLASSES_WORKSHOPS
  OTHER
}

// Event submission status
enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// One-time or recurring events with specific dates
model Event {
  id              String    @id @default(cuid())
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  venue           String
  address         String?
  city            String    @default("Nyack")
  isNyackProper   Boolean   @default(true)
  category        Category  @default(OTHER)
  price           String?   // e.g., "Free", "$20", "$15-$30"
  isFree          Boolean   @default(false)
  isFamilyFriendly Boolean  @default(false)
  sourceUrl       String
  sourceName      String    // e.g., "Visit Nyack", "Levity Live"
  imageUrl        String?
  isHidden        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // For deduplication - hash of title + venue + startDate
  sourceHash      String?   @unique

  // Recurrence fields (for recurring events like "Every Tuesday")
  isRecurring         Boolean   @default(false)
  recurrenceDays      Int[]     // Array of day numbers: 0=Sun, 1=Mon, 2=Tue, ..., 6=Sat
  recurrenceEndDate   DateTime? // Optional end date for recurrence

  // Link from approved submission
  submission      EventSubmission?

  @@index([startDate])
  @@index([category])
  @@index([isHidden])
  @@index([isFamilyFriendly])
  @@index([isRecurring])
}

// Always-available activities (go-karts, bowling, etc.)
model Activity {
  id              String    @id @default(cuid())
  title           String
  description     String
  venue           String
  address         String
  city            String    @default("Nyack")
  isNyackProper   Boolean   @default(true)
  category        Category  @default(OTHER)
  price           String?
  isFree          Boolean   @default(false)
  isFamilyFriendly Boolean  @default(false)
  hours           String?   // e.g., "Mon-Fri 10am-9pm"
  websiteUrl      String
  imageUrl        String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([isFamilyFriendly])
}

// Track scraper runs for debugging
model ScraperLog {
  id          String   @id @default(cuid())
  sourceName  String
  status      String   // "success", "error", "partial"
  eventsFound Int      @default(0)
  eventsAdded Int      @default(0)
  errorMessage String?
  runAt       DateTime @default(now())

  @@index([sourceName])
  @@index([runAt])
}

// User-submitted events pending admin review
model EventSubmission {
  id              String    @id @default(cuid())

  // Required fields
  title           String
  startDate       DateTime
  venue           String
  submitterEmail  String

  // Optional event details
  description     String?
  endDate         DateTime?
  address         String?
  city            String    @default("Nyack")
  category        Category  @default(OTHER)
  price           String?
  isFree          Boolean   @default(false)
  isFamilyFriendly Boolean  @default(false)
  sourceName      String?   // "Manual Form", "Email", "Discord"
  sourceUrl       String?
  imageUrl        String?

  // Recurrence fields (for recurring events like "Every Tuesday")
  isRecurring         Boolean   @default(false)
  recurrenceDays      Int[]     // Array of day numbers: 0=Sun, 1=Mon, 2=Tue, ..., 6=Sat
  recurrenceEndDate   DateTime? // Optional end date for recurrence

  // Admin workflow fields
  status          SubmissionStatus @default(PENDING)
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  rejectionReason String?

  // Link to approved event
  approvedEventId String?   @unique
  approvedEvent   Event?    @relation(fields: [approvedEventId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([submittedAt])
}

// Discord messages processed for event extraction
model DiscordMessage {
  id              String   @id @default(cuid())

  // Discord metadata
  messageId       String   @unique  // Discord snowflake ID
  channelId       String              // Which channel this came from
  channelName     String              // Human-readable channel name
  authorId        String              // Discord user ID who posted
  authorName      String              // Discord username
  content         String   @db.Text   // Message text content
  attachmentUrls  String[] @default([]) // Array of image URLs
  postedAt        DateTime            // When message was posted to Discord

  // Processing metadata
  processedAt     DateTime @default(now())
  status          String   // "success", "error", "no_events"
  eventsExtracted Int      @default(0)
  errorMessage    String?

  @@index([channelId])
  @@index([processedAt])
  @@index([status])
}
