# Database (Supabase PostgreSQL)
# Get these from your Supabase project: Settings > Database
#
# DATABASE_URL: Used by Prisma for migrations (uses transaction pooling)
# DIRECT_URL: Used by Prisma Client at runtime (bypasses RLS with service role)
#
# IMPORTANT: DIRECT_URL must use the service role key to bypass RLS
# Format: postgresql://postgres.[project-ref]:[service-role-password]@...
# Get service role password from: Supabase Dashboard > Settings > Database > Connection string > Session
# Replace [password] with your service role password (starts with "eyJ...")
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[service-role-password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Admin Authentication
# Set a strong password for admin access
ADMIN_PASSWORD="your-secure-admin-password"

# Scraper API Key (optional, for securing cron job)
# Generate a random string: openssl rand -hex 32
SCRAPER_API_KEY="your-scraper-api-key"

# Site URL (for SEO metadata)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Notifications (optional)
# Discord: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=""
# Slack: Apps > Incoming Webhooks
SLACK_WEBHOOK_URL=""

# Email Newsletter Scraper (optional)
# Gmail API OAuth - See docs/email-scraper-setup.md for setup instructions
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="http://localhost:3000/api/admin/gmail/callback"
GMAIL_REFRESH_TOKEN=""
GMAIL_ACCESS_TOKEN=""

# Email Processing Configuration
EMAIL_SENDER_ALLOWLIST='[]'  # JSON array of allowed sender emails, e.g., '["newsletter@visitnyack.org","events@nyackchamber.org"]'
EMAIL_MAX_AGE_DAYS="7"  # Only process emails from last N days
EMAIL_MAX_PER_RUN="50"  # Maximum emails to process per scraper run

# AI Event Extraction (required for email scraper)
# Get OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Or use Anthropic (optional fallback): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# AI Configuration (optional - defaults shown)
AI_PROVIDER="openai"  # "openai" or "anthropic"
AI_MODEL="gpt-4o"  # or "claude-3-5-sonnet-20241022" for Anthropic
AI_MAX_TOKENS="4096"
AI_TEMPERATURE="0.1"
